# Environment and secrets
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# Python
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
backend/.venv/
backend/*.egg-info/

# Node / frontend build artifacts
frontend/node_modules/
frontend/dist/
frontend/playwright-report/
frontend/test-results/
frontend/*.tsbuildinfo

# Local browser/test artifacts
.tmp/
dashboard-visual-check*.png
schedule-*.png

# Temporary docs exports
docs/_tmp_*

# Local editors
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Private certificates/keys
backend/certs/*.key
backend/certs/*.p12
backend/certs/*.pfx
